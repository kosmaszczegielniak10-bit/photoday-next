# PhotoDay 2.0 Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Supabase ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://drcmantndmqrcwpcezoy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Service role key — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ── Auth ──────────────────────────────────────
# Keep the same secret as the old backend so existing JWTs remain valid!
JWT_SECRET=YOUR_EXISTING_JWT_SECRET_HERE

# ── App ───────────────────────────────────────
NEXT_PUBLIC_APP_NAME=PhotoDay
NODE_ENV=development
